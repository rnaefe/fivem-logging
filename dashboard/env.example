# ===========================================
# FiveM Logs Dashboard - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=fivem_logs

# JWT Secret (generate a strong random string - at least 32 characters)
# You can generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Discord OAuth2
# Create an application at https://discord.com/developers/applications
# Add OAuth2 redirect URL: http://localhost:3001/api/auth/callback
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Elasticsearch API (Backend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ===========================================
# Discord Setup Instructions:
# ===========================================
# 1. Go to https://discord.com/developers/applications
# 2. Click "New Application" and give it a name
# 3. Go to OAuth2 > General
# 4. Copy the Client ID and Client Secret
# 5. Add redirect URL: http://localhost:3001/api/auth/callback
# 6. Go to OAuth2 > URL Generator
# 7. Select scopes: identify, email, guilds, guilds.members.read
# ===========================================

