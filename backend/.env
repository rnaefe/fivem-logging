# ===========================================
# FiveM Logs Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Port
PORT=3001

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=fivem-logs

# Optional: Elasticsearch authentication (if enabled)
ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=

# ===========================================
# Elasticsearch Setup:
# ===========================================
# 1. Download Elasticsearch 9.x from elastic.co
# 2. Run: bin/elasticsearch
# 3. Default runs on http://localhost:9200
# 4. Optional: Run Kibana for visualization
#    - Download Kibana 9.x
#    - Run: bin/kibana
#    - Access at http://localhost:5601
# ===========================================

